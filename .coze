[project]
requires = [ "nodejs-24" ]
template = "nextjs"
version = "legacy"
appliedPatches = [ "nextjs/replace-npx-with-pnpm@0.0.13" ]

[dev]
build = [ "pnpm", "install" ]
run = [ "pnpm", "dev" ]
deps = [ "git" ]

[deploy]
build = [ "pnpm", "install", "&&", "pnpm", "run", "build" ]
run = [ "pnpm", "run", "start" ]
deps = [ "git" ]
